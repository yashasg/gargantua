# Gargantua release-pipeline environment.
#
# Copy to .env.release (gitignored) and fill in. Any var can also be exported
# directly in the shell or CI; real env always wins over this file.

# Apple Developer team identifier (10-char alphanumeric). Visible in
# https://developer.apple.com/account → Membership.
TEAM_ID=

# Exact codesign identity string or SHA-1 hash. For distribution, this must
# resolve to a "Developer ID Application: ..." cert in the login Keychain. Find with:
#   security find-identity -v -p codesigning
# Example:
#   SIGNING_IDENTITY="Developer ID Application: Jane Doe (ABCDE12345)"
SIGNING_IDENTITY=

# notarytool keychain profile name. Create once with:
#   xcrun notarytool store-credentials "gargantua-notary" \
#     --apple-id you@example.com \
#     --team-id $TEAM_ID \
#     --password <app-specific-password>
NOTARY_PROFILE=gargantua-notary

# Bundle identifiers. Only override if you're forking / white-labeling.
# BUNDLE_ID=com.inceptyon.gargantua
# HELPER_BUNDLE_ID=com.inceptyon.gargantua.privileged-helper
